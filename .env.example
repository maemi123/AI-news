# Bilibili
BILIBILI_SESSDATA=your_sessdata_here
BILIBILI_BILI_JCT=
BILIBILI_BUVID3=
DEBUG=false
WEIBO_COOKIES=

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Whisper compatible API
WHISPER_API_KEY=
WHISPER_BASE_URL=https://aihubmix.com/v1
WHISPER_MODEL=whisper-large-v3

# Dual-host podcast TTS
PODCAST_AUDIO_ENABLED=false
PODCAST_INCLUDE_AUDIO_LINK=true
PODCAST_CHANNEL=built_in
TTS_API_KEY=
TTS_BASE_URL=https://api.openai.com/v1
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE_MALE=alloy
TTS_VOICE_FEMALE=nova
TTS_FORMAT=wav

# Edge TTS 推荐中文音色：
# TTS_VOICE_MALE=zh-CN-YunyangNeural
# TTS_VOICE_FEMALE=zh-CN-XiaoxiaoNeural

# Object storage for podcast audio
AUDIO_STORAGE_PROVIDER=s3
AUDIO_STORAGE_ENDPOINT=
AUDIO_STORAGE_BUCKET=
AUDIO_STORAGE_ACCESS_KEY=
AUDIO_STORAGE_SECRET_KEY=
AUDIO_STORAGE_REGION=auto
AUDIO_STORAGE_PUBLIC_BASE_URL=

# Database
DATABASE_URL=sqlite+aiosqlite:///./ai_news.db

# PushPlus
PUSHPLUS_TOKEN=
WECOM_WEBHOOK_URL=

# Optional: point the app to your self-hosted RSSHub
RSSHUB_BASE_URL=

# Legacy single-video targets
TARGET_UP_IDS=

# Scheduler
SCHEDULER_ENABLED=true
DAILY_REPORT_HOUR=9
DAILY_REPORT_MINUTE=0
FETCH_LOOKBACK_HOURS=24
SCHEDULER_TIMEZONE=Asia/Shanghai

# Seed curated default monitor sources on startup
SEED_DEFAULT_MONITOR_SOURCES=true
