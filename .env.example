# 推送
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./ai_news.db

# 要监控的UP主（支持多个，逗号分隔）
TARGET_UP_IDS=285286947
