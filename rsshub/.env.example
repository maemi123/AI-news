# RSSHub service
PORT=1200
NODE_ENV=production
CACHE_TYPE=memory

# Weibo
# Fill this with the full cookie string copied from an authenticated browser session.
WEIBO_COOKIES=

# X / Twitter
# RSSHub's twitter/user route needs a real logged-in account in practice.
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
